# ---------------------------------------------------------------------------
# Configuración del Asistente RAG jerárquico + MCP
# Copia este archivo a .env y rellena tu clave:   cp .env.example .env
# NO subas el archivo .env al repositorio (está en .gitignore).
# ---------------------------------------------------------------------------

# --- OpenAI (obligatorio) --------------------------------------------------
# Clave de la API de OpenAI. Sin ella no se puede indexar ni responder.
OPENAI_API_KEY=sk-

# Endpoint compatible con la API de OpenAI (opcional: Azure, proxy, etc.).
# Déjalo vacío para usar la API pública de OpenAI.
OPENAI_BASE_URL=https://api.openai.com/v1

# Modelo de generación y de routing.
OPENAI_MODEL=gpt-4o-mini

# Modelo de embeddings para el índice vectorial.
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- Servidor MCP ----------------------------------------------------------
# En docker-compose este valor se sobreescribe a http://mcp-server:8000.
# Para ejecución local fuera de Docker, usa http://localhost:8000.
MCP_SERVER_URL=http://localhost:8000

# Timeout (segundos) y reintentos de cada llamada a una tool MCP.
MCP_TOOL_TIMEOUT=12
MCP_TOOL_RETRIES=2

# --- Observabilidad --------------------------------------------------------
LOG_LEVEL=INFO

# --- Parámetros opcionales de chunking y recuperación ----------------------
# (tienen valores por defecto razonables; descoméntalos solo para ajustar)
# PARENT_CHUNK_SIZE=1800
# CHILD_CHUNK_SIZE=450
# TOP_K_CHILDREN=6
# MAX_PARENTS=3
